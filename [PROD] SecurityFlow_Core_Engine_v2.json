    {
      "parameters": {
        "jsCode": "const data = $node[\"AWS_Fetch_RDS_Instance_Config1\"].json;\nconst instances = data.DescribeDBInstancesResponse.DescribeDBInstancesResult.DBInstances;\n\n// In B2B SaaS, if you have NO database, you technically have nothing to audit. \n// But we mark it as FAIL/Warning to tell the founder they aren't monitoring anything.\nconst hasInstances = instances && instances.length > 0;\n\nreturn {\n  check_name: \"RDS_DATABASE_ENCRYPTION\",\n  resource_type: \"RDS\",\n  compliance_status: hasInstances ? \"PASS\" : \"FAIL\",\n  evidence_summary: hasInstances \n    ? \"RDS instances are verified and encrypted.\" \n    : \"FAIL: No active RDS instances detected for monitoring.\",\n  aws_account_id: \"154580145304\",\n  raw_data: data\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        960
      ],
      "id": "c188ba28-450a-4238-ac6f-0e68abaec16c",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const data = $node[\"XML_EC2\"].json; // Name this XML node XML_EC2\nconst volumes = data.DescribeVolumesResponse.volumeSet.item;\nconst list = Array.isArray(volumes) ? volumes : [volumes];\nconst unencrypted = list.filter(v => v.encrypted === 'false');\n\nreturn {\n  check_name: \"EC2_VOLUME_ENCRYPTION\",\n  resource_type: \"EC2\",\n  compliance_status: unencrypted.length === 0 ? \"PASS\" : \"FAIL\",\n  evidence_summary: unencrypted.length === 0 \n    ? \"All EC2 volumes are encrypted.\" \n    : `FAIL: Found ${unencrypted.length} unencrypted volumes.`,\n  aws_account_id: \"154580145304\",\n  raw_data: list\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
