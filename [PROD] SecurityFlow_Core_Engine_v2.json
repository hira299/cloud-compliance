    {
      "parameters": {
        "jsCode": "const data = $node[\"XML\"].json; // Assumes your XML node is named \"XML\"\nconst config = data?.PublicAccessBlockConfiguration;\n\nif (!config) {\n  return {\n    check_name: \"S3_BUCKET_PRIVACY\",\n    resource_type: \"S3\",\n    compliance_status: \"MANUAL_REVIEW\",\n    evidence_summary: \"Could not retrieve S3 Public Access Block settings. Check if bucket exists or permissions.\",\n    aws_account_id: \"154580145304\",\n    raw_data: data\n  };\n}\n\nconst isSecure = config.BlockPublicAcls === 'true' && config.BlockPublicPolicy === 'true';\n\nreturn {\n  check_name: \"S3_BUCKET_PRIVACY\",\n  resource_type: \"S3\",\n  compliance_status: isSecure ? \"PASS\" : \"FAIL\",\n  evidence_summary: isSecure \n    ? \"S3 Public Access is successfully blocked (Encrypted/Private).\" \n    : \"FAIL: S3 Bucket allows public ACLs or Policies. High risk of data leak.\",\n  aws_account_id: \"154580145304\",\n  raw_data: config\n};"
      },
