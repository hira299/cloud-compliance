    },
    {
      "parameters": {
        "jsCode": "const data = $node[\"XML_VPC\"].json; // Name this XML node XML_VPC\nconst logs = data.DescribeFlowLogsResponse.flowLogSet;\n\n// If the flowLogSet is empty, network logging is OFF.\nconst isLogging = Object.keys(logs).length > 0;\n\nreturn {\n  check_name: \"VPC_FLOW_LOGGING\",\n  resource_type: \"VPC\",\n  compliance_status: isLogging ? \"PASS\" : \"FAIL\",\n  evidence_summary: isLogging \n    ? \"VPC network traffic is being logged.\" \n    : \"FAIL: VPC Flow Logs are disabled. No network audit trail exists.\",\n  aws_account_id: \"154580145304\",\n  raw_data: data\n};"
      },
