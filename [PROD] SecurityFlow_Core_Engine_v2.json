      "parameters": {
        "jsCode": "const user = items[0].json;\n\nif (!user || !user.Arn) {\n  return {\n    check_name: \"IAM_USER_INVENTORY\",\n    resource_type: \"IAM\",\n    compliance_status: \"MANUAL_REVIEW\",\n    evidence_summary: \"Failed to retrieve IAM user list.\",\n    aws_account_id: \"154580145304\",\n    raw_data: user\n  };\n}\n\nreturn {\n  check_name: \"IAM_USER_INVENTORY\",\n  resource_type: \"IAM\",\n  compliance_status: \"PASS\",\n  evidence_summary: `Verified active IAM Scanner user: ${user.UserName}.`,\n  aws_account_id: \"154580145304\",\n  raw_data: user\n};"
