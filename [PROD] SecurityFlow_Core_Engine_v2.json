    {
      "parameters": {
        "jsCode": "const data = $node[\"AWS_Fetch_IAM_Password_Policy\"].json;\nconst summary = data?.GetAccountSummaryResponse?.GetAccountSummaryResult?.SummaryMap;\n\n// Error Handling: If the API didn't return the SummaryMap\nif (!summary) {\n  return {\n    check_name: \"IAM_PASSWORD_COMPLIANCE\",\n    resource_type: \"IAM\",\n    compliance_status: \"MANUAL_REVIEW\",\n    evidence_summary: \"Error: Could not retrieve Account Summary. API response was malformed or denied.\",\n    aws_account_id: \"154580145304\",\n    raw_data: data\n  };\n}\n\nconst isCompliant = summary.AccountPasswordPresent === 1;\n\nreturn {\n  check_name: \"IAM_PASSWORD_COMPLIANCE\",\n  resource_type: \"IAM\",\n  compliance_status: isCompliant ? \"PASS\" : \"FAIL\",\n  evidence_summary: isCompliant \n    ? \"IAM Password policy is strictly enforced.\" \n    : \"FAIL: No custom IAM password policy found. Default AWS policy is too weak.\",\n  aws_account_id: \"154580145304\",\n  raw_data: summary\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        576
      ],
      "id": "4ae2fcaa-573b-4412-87ad-e294083b1034",
